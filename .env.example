# Supabase configuration
# Copy to .env and fill in your values. Never commit .env.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Sentry (optional - errors are no-op if DSN not set)
VITE_SENTRY_DSN=https://31a93bdc0540bdb9ed99d778586a59f4@o4510965164015616.ingest.us.sentry.io/4510965166374912
VITE_SENTRY_ENVIRONMENT=development

# Cloudflare Turnstile (optional - invisible CAPTCHA for login/signup/forgot-password)
# Get free keys at https://dash.cloudflare.com/?to=/:account/turnstile
# VITE_TURNSTILE_SITE_KEY=your_site_key
# Set TURNSTILE_SECRET_KEY in Supabase Edge Function secrets: supabase secrets set TURNSTILE_SECRET_KEY=your_secret

# Source map upload (build-time only; for readable stack traces in Sentry)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token
